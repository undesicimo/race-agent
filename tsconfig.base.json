{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "@sim-telemetry/analysis": ["./packages/analysis/src"],
      "@sim-telemetry/database": ["./packages/database/src"],
      "@sim-telemetry/telemetry-schema": ["./packages/telemetry-schema/src"]
    }
  }
}
