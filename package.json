{
  "name": "race-agent",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm lint && pnpm typecheck && cargo check --workspace",
    "db:generate": "pnpm --filter @race-agent/database db:generate",
    "db:logs": "docker compose logs -f db",
    "db:migrate": "pnpm --filter @race-agent/database db:migrate",
    "db:stop": "docker compose stop db",
    "db:up": "node scripts/check-docker.mjs && docker compose up -d --wait db",
    "dev": "pnpm dev:local",
    "dev:local": "pnpm db:up && pnpm db:migrate && pnpm dev:web",
    "dev:web": "pnpm --filter @race-agent/web dev",
    "dev:mcp": "pnpm --filter @race-agent/mcp dev",
    "lint": "oxlint",
    "lint:commits": "commitlint --from HEAD~1 --to HEAD",
    "lint:fix": "oxlint --fix",
    "rust:check": "cargo check --workspace",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
