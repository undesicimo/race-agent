{
  "name": "sim-telemetry",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "check": "pnpm lint && pnpm typecheck && cargo check --workspace",
    "db:generate": "pnpm --filter @sim-telemetry/database db:generate",
    "db:migrate": "pnpm --filter @sim-telemetry/database db:migrate",
    "dev:web": "pnpm --filter @sim-telemetry/web dev",
    "dev:mcp": "pnpm --filter @sim-telemetry/mcp dev",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "rust:check": "cargo check --workspace",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "oxlint": "^1.70.0",
    "oxlint-tsgolint": "^0.23.0",
    "typescript": "^6.0.3"
  }
}
